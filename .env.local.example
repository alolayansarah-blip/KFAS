# Copy this file to .env.local and fill in your values

# PURE API (for StatsCounter - required for production)
PURE_API_KEY=181b5f03-d95d-47be-9fe8-96342b42deab

# MongoDB (get from https://cloud.mongodb.com)
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/kfastest?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_user:your_password@cluster0.xxxxx.mongodb.net/kfastest?retryWrites=true&w=majority

# Instagram (optional - for Instagram feed)
# INSTAGRAM_ACCESS_TOKEN=your_token

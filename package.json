{
  "name": "kfastest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Removed .next');}catch(e){if(e.code!=='ENOENT')throw e;}\"",
    "dev": "npx --yes kill-port 3000 && next dev -H 0.0.0.0 -p 3000",
    "dev:alt": "next dev -H 0.0.0.0 -p 3009",
    "dev:tunnel": "lt --port 3000",
    "dev:share": "ngrok http 3001",
    "build": "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.23.24",
    "gsap": "^3.14.2",
    "lucide-react": "^0.563.0",
    "mongodb": "^7.1.0",
    "next": "^14.2.0",
    "next-intl": "^4.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-simple-maps": "^3.0.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-simple-maps": "^3.0.6",
    "autoprefixer": "^10.4.0",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": "22.x"
  }
}
